{
  "name": "sarif-viewer",
  "version": "0.1.0",
  "description": "A CLI tool to view and convert SARIF files to terminal text and interactive HTML",
  "type": "module",
  "bin": {
    "sarif-viewer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/sarif": "^2.1.7",
    "@types/node": "^22.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
